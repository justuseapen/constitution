<div class="max-w-4xl mx-auto py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold">Blueprints</h1>
      <p class="text-gray-500 text-sm"><%= @project.name %></p>
    </div>
    <%= link_to "New Blueprint", new_project_blueprint_path(@project), class: "px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700" %>
  </div>

  <div class="space-y-3">
    <% @blueprints.each do |blueprint| %>
      <%= link_to project_blueprint_path(@project, blueprint), class: "block p-4 border rounded hover:bg-gray-50" do %>
        <div class="flex justify-between items-start">
          <div>
            <h2 class="font-semibold"><%= blueprint.title %></h2>
            <span class="text-xs px-2 py-0.5 rounded bg-gray-200 text-gray-600"><%= blueprint.blueprint_type.humanize %></span>
          </div>
          <span class="text-xs text-gray-400">v<%= blueprint.version %></span>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
