<%= form_with(model: [@project, blueprint], class: "space-y-4") do |f| %>
  <% if blueprint.errors.any? %>
    <div class="bg-red-50 p-4 rounded">
      <% blueprint.errors.full_messages.each do |msg| %>
        <p class="text-red-600 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :title, class: "mt-1 block w-full border rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.label :blueprint_type, class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :blueprint_type, Blueprint.blueprint_types.keys.map { |k| [k.humanize, k] },
        {}, class: "mt-1 block w-full border rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.label :document_id, "Source Document (optional)", class: "block text-sm font-medium text-gray-700" %>
    <%= f.collection_select :document_id, @project.documents.order(:title), :id, :title,
        { include_blank: "None" }, class: "mt-1 block w-full border rounded px-3 py-2" %>
  </div>

  <div data-controller="tiptap" data-tiptap-content-value="<%= blueprint.body %>">
    <label class="block text-sm font-medium text-gray-700 mb-1">Content</label>
    <div data-tiptap-target="editor" class="prose max-w-none min-h-[300px] border rounded p-4 bg-white"></div>
    <%= f.hidden_field :body, data: { tiptap_target: "input" } %>
  </div>

  <div>
    <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>
