<div class="w-full max-w-md mx-auto mt-16">
  <div class="text-center mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Welcome to Constitution</h1>
    <p class="text-sm text-gray-500 mt-1">Set up your workspace to get started</p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
    <%= form_tag onboarding_path, method: :post do %>
      <% if flash[:alert] %>
        <div class="mb-5 p-3 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-red-600 text-sm"><%= flash[:alert] %></p>
        </div>
      <% end %>

      <div class="space-y-6">
        <div>
          <h2 class="text-lg font-semibold text-gray-800 mb-1">Create your team</h2>
          <p class="text-sm text-gray-500 mb-3">A team is your shared workspace for managing projects.</p>
          <label for="team_name" class="block text-sm font-medium text-gray-700 mb-1">Team name</label>
          <input type="text" name="team_name" id="team_name" autofocus required
                 value="<%= params[:team_name] %>"
                 class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition"
                 placeholder="e.g. Acme Engineering">
        </div>

        <hr class="border-gray-200">

        <div>
          <h2 class="text-lg font-semibold text-gray-800 mb-1">Create your first project</h2>
          <p class="text-sm text-gray-500 mb-3">Optional. You can always create projects later.</p>
          <label for="project_name" class="block text-sm font-medium text-gray-700 mb-1">Project name</label>
          <input type="text" name="project_name" id="project_name"
                 value="<%= params[:project_name] %>"
                 class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition"
                 placeholder="e.g. Mobile App Redesign">
        </div>

        <div>
          <button type="submit"
                  class="w-full py-2.5 px-4 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition cursor-pointer">
            Get Started
          </button>
        </div>
      </div>
    <% end %>
  </div>
</div>
