<%= form_with(model: service_system, url: service_system.persisted? ? system_path(service_system) : systems_path, class: "space-y-4") do |f| %>
  <% if service_system.errors.any? %>
    <div class="bg-red-50 p-4 rounded">
      <% service_system.errors.full_messages.each do |msg| %>
        <p class="text-red-600 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, class: "mt-1 block w-full border rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.label :system_type, class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :system_type, ServiceSystem.system_types.keys.map { |k| [k.humanize, k] },
        {}, class: "mt-1 block w-full border rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.label :repo_url, "Repository URL", class: "block text-sm font-medium text-gray-700" %>
    <%= f.url_field :repo_url, class: "mt-1 block w-full border rounded px-3 py-2", placeholder: "https://github.com/..." %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :description, rows: 3, class: "mt-1 block w-full border rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>
