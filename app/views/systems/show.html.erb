<div class="p-6 max-w-4xl">
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-2xl font-bold"><%= @system.name %></h1>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_system_path(@system), class: "px-3 py-1 border rounded text-sm" %>
      <%= link_to "System Map", systems_path, class: "px-3 py-1 border rounded text-sm" %>
    </div>
  </div>

  <div class="flex gap-2 mb-4">
    <span class="px-2 py-1 rounded text-xs font-medium bg-blue-100 text-blue-800"><%= @system.system_type.humanize %></span>
    <% if @system.repo_url.present? %>
      <%= link_to @system.repo_url, @system.repo_url, target: "_blank", class: "text-sm text-indigo-600 hover:underline" %>
    <% end %>
  </div>

  <% if @system.description.present? %>
    <div class="prose max-w-none mb-6">
      <p><%= @system.description %></p>
    </div>
  <% end %>

  <h2 class="text-lg font-semibold mb-3">Dependencies</h2>

  <% if @system.outgoing_dependencies.any? %>
    <h3 class="text-sm font-medium text-gray-600 mb-2">Outgoing</h3>
    <div class="space-y-2 mb-4">
      <% @system.outgoing_dependencies.includes(:target_system).each do |dep| %>
        <div class="flex items-center gap-2 p-2 bg-gray-50 rounded">
          <span class="text-sm font-medium"><%= dep.target_system.name %></span>
          <span class="text-xs px-2 py-0.5 rounded bg-blue-100 text-blue-800"><%= dep.dependency_type.humanize %></span>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @system.incoming_dependencies.any? %>
    <h3 class="text-sm font-medium text-gray-600 mb-2">Incoming</h3>
    <div class="space-y-2">
      <% @system.incoming_dependencies.includes(:source_system).each do |dep| %>
        <div class="flex items-center gap-2 p-2 bg-gray-50 rounded">
          <span class="text-sm font-medium"><%= dep.source_system.name %></span>
          <span class="text-xs px-2 py-0.5 rounded bg-green-100 text-green-800"><%= dep.dependency_type.humanize %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
