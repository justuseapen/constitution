<div class="flex h-[calc(100vh-4rem)]">
  <!-- Main editor area -->
  <div class="flex-1 p-8 overflow-y-auto">
    <div class="max-w-3xl mx-auto">
      <div class="mb-4">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs px-2 py-0.5 rounded bg-gray-200 text-gray-600 uppercase"><%= @document.document_type.humanize %></span>
          <%= link_to "Edit", edit_project_document_path(@project, @document), class: "text-xs text-indigo-600 hover:underline" %>
          <%= link_to "All Docs", project_documents_path(@project), class: "text-xs text-gray-500 hover:underline" %>
        </div>
        <h1 class="text-3xl font-bold"><%= @document.title %></h1>
        <p class="text-sm text-gray-500">
          v<%= @document.version %> &middot; by <%= @document.updated_by&.name || @document.created_by.name %>
        </p>
      </div>

      <div class="prose max-w-none">
        <%= @document.body&.html_safe %>
      </div>
    </div>
  </div>

  <!-- Agent sidebar -->
  <%= render "agent_chats/sidebar", conversable_type: "Document", conversable_id: @document.id %>
</div>
