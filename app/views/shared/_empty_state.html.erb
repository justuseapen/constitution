<%# Usage: render "shared/empty_state", title: "No work orders yet", description: "...", action_text: "Create Work Order", action_path: new_..._path %>
<div class="text-center py-12">
  <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-2.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
  </svg>
  <h3 class="mt-3 text-sm font-semibold text-gray-900"><%= local_assigns[:title] || "Nothing here yet" %></h3>
  <% if local_assigns[:description] %>
    <p class="mt-1 text-sm text-gray-500"><%= description %></p>
  <% end %>
  <% if local_assigns[:action_text] && local_assigns[:action_path] %>
    <div class="mt-4">
      <%= link_to action_text, action_path, class: "inline-flex items-center gap-1 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700" %>
    </div>
  <% end %>
</div>
