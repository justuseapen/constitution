<aside class="w-64 bg-gray-900 text-white flex flex-col h-full flex-shrink-0">
  <div class="p-4 border-b border-gray-700">
    <h1 class="text-lg font-bold tracking-tight">Constitution</h1>
    <p class="text-xs text-gray-400 mt-1"><%= current_user.team&.name || "No team" %></p>
  </div>

  <% if @project&.persisted? %>
    <div class="p-4 border-b border-gray-700">
      <p class="text-xs text-gray-400 uppercase tracking-wider mb-2">Project</p>
      <p class="text-sm font-medium truncate"><%= @project.name %></p>
    </div>

    <nav class="flex-1 p-4 space-y-1">
      <p class="text-xs text-gray-400 uppercase tracking-wider mb-2">Modules</p>

      <%= sidebar_link "Refinery", project_documents_path(@project), icon: "document-text" %>
      <%= sidebar_link "Foundry", project_blueprints_path(@project), icon: "cube" %>
      <%= sidebar_link "Planner", project_work_orders_path(@project), icon: "clipboard-document-list" %>
      <%= sidebar_link "Validator", project_feedback_items_path(@project), icon: "inbox-arrow-down" %>

      <div class="pt-4">
        <p class="text-xs text-gray-400 uppercase tracking-wider mb-2">Infrastructure</p>
        <%= sidebar_link "Systems", systems_path, icon: "server-stack" %>
        <%= sidebar_link "Graph Explorer", graph_explorer_path, icon: "share" %>
      </div>
    </nav>
  <% else %>
    <nav class="flex-1 p-4 space-y-1">
      <p class="text-xs text-gray-400 uppercase tracking-wider mb-2">Navigation</p>
      <%= sidebar_link "Projects", projects_path, icon: "folder" %>
      <%= sidebar_link "Systems", systems_path, icon: "server-stack" %>
      <%= sidebar_link "Graph Explorer", graph_explorer_path, icon: "share" %>
    </nav>
  <% end %>

  <div class="p-4 border-t border-gray-700">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-indigo-500 rounded-full flex items-center justify-center text-sm font-medium">
        <%= current_user.name&.first&.upcase %>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm truncate"><%= current_user.name %></p>
        <p class="text-xs text-gray-400 truncate"><%= current_user.email %></p>
      </div>
    </div>
    <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "mt-3 block text-xs text-gray-400 hover:text-white" %>
  </div>
</aside>
