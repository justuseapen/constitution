<div class="w-full max-w-sm">
  <div class="text-center mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Constitution</h1>
    <p class="text-sm text-gray-500 mt-1">Reset your password</p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <% if resource.errors.any? %>
        <div class="mb-5 p-3 bg-red-50 border border-red-200 rounded-lg">
          <% resource.errors.full_messages.each do |msg| %>
            <p class="text-red-600 text-sm"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="space-y-5">
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition",
              placeholder: "you@example.com" %>
        </div>

        <div>
          <%= f.submit "Send reset instructions",
              class: "w-full py-2.5 px-4 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>

  <%= render "devise/shared/links" %>
</div>
