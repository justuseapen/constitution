<%- if controller_name != 'sessions' %>
  <p class="mt-4 text-center text-sm text-gray-400">
    Already have an account?
    <%= link_to "Sign in", new_session_path(resource_name), class: "text-indigo-400 hover:text-indigo-300 font-medium" %>
  </p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p class="mt-4 text-center text-sm text-gray-400">
    Don't have an account?
    <%= link_to "Sign up", new_registration_path(resource_name), class: "text-indigo-400 hover:text-indigo-300 font-medium" %>
  </p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p class="mt-2 text-center text-sm">
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-gray-500 hover:text-gray-300" %>
  </p>
<% end %>
