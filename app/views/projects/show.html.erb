<% content_for(:page_title, "Dashboard") %>

<div class="space-y-6">
  <!-- Project Header -->
  <div class="flex justify-between items-start">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @project.name %></h1>
      <p class="text-gray-500 mt-1"><%= @project.description %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_project_path(@project), class: "px-3 py-1.5 text-sm border rounded-lg hover:bg-gray-50" %>
      <span class="px-3 py-1.5 text-sm rounded-lg <%= @project.active? ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
        <%= @project.status.humanize %>
      </span>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="bg-white rounded-lg border p-4">
      <p class="text-sm text-gray-500">Documents</p>
      <p class="text-2xl font-bold text-gray-900"><%= @project.documents.count %></p>
    </div>
    <div class="bg-white rounded-lg border p-4">
      <p class="text-sm text-gray-500">Blueprints</p>
      <p class="text-2xl font-bold text-gray-900"><%= @project.blueprints.count %></p>
    </div>
    <div class="bg-white rounded-lg border p-4">
      <p class="text-sm text-gray-500">Open Work Orders</p>
      <p class="text-2xl font-bold text-gray-900"><%= @project.work_orders.where.not(status: :done).count %></p>
    </div>
    <div class="bg-white rounded-lg border p-4" title="Drift alerts flag when a document, blueprint, or work order has changed but its downstream artifacts haven't been updated yet.">
      <p class="text-sm text-gray-500">Drift Alerts</p>
      <p class="text-2xl font-bold <%= @project.drift_alerts.where(status: :open).any? ? 'text-amber-600' : 'text-gray-900' %>">
        <%= @project.drift_alerts.where(status: :open).count %>
      </p>
    </div>
  </div>

  <!-- Repositories -->
  <div class="bg-white rounded-lg border" data-controller="indexing-progress" data-indexing-progress-project-id-value="<%= @project.id %>">
    <div class="px-4 py-3 border-b flex justify-between items-center">
      <h2 class="font-semibold text-gray-900">Repositories</h2>
    </div>
    <div class="p-4">
      <% repos = current_user.team.service_systems.joins(:repositories).includes(:repositories).flat_map(&:repositories) %>
      <% if repos.any? %>
        <div class="space-y-2 mb-4">
          <% repos.each do |repo| %>
            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg" data-repo-id="<%= repo.id %>">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= repo.name %></p>
                  <p class="text-xs text-gray-400"><%= repo.url %></p>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <% if repo.failed? %>
                  <%= button_to "Retry", retry_index_project_repository_path(@project, repo), method: :post, class: "text-xs px-2 py-1 bg-indigo-600 text-white rounded hover:bg-indigo-700 cursor-pointer" %>
                <% end %>
                <span data-indexing-status class="text-xs px-2 py-1 rounded-full
                  <%= case repo.indexing_status
                      when 'indexed' then 'bg-green-100 text-green-700'
                      when 'indexing' then 'bg-blue-100 text-blue-700'
                      when 'failed' then 'bg-red-100 text-red-700'
                      else 'bg-gray-100 text-gray-600'
                      end %>">
                  <%= repo.indexing_status.humanize %>
                </span>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= form_with url: project_repositories_path(@project), method: :post, class: "flex gap-2" do |f| %>
        <%= f.text_field :repository_url,
            placeholder: "https://github.com/org/repo.git",
            class: "flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none" %>
        <%= f.submit "Connect Repository",
            class: "px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Active Drift Alerts -->
    <div class="bg-white rounded-lg border">
      <div class="px-4 py-3 border-b">
        <h2 class="font-semibold text-gray-900" title="Upstream artifacts changed but downstream artifacts haven't been updated yet.">Active Drift Alerts</h2>
      </div>
      <div class="p-4">
        <% alerts = @project.drift_alerts.where(status: :open).order(created_at: :desc).limit(5) %>
        <% if alerts.any? %>
          <div class="space-y-3">
            <% alerts.each do |alert| %>
              <div class="flex items-start gap-3 p-3 bg-amber-50 rounded-lg">
                <svg class="w-5 h-5 text-amber-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
                <div>
                  <p class="text-sm text-gray-700"><%= alert.message %></p>
                  <p class="text-xs text-gray-400 mt-1"><%= time_ago_in_words(alert.created_at) %> ago</p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-400">No active drift alerts</p>
        <% end %>
      </div>
    </div>

    <!-- Work Order Summary -->
    <div class="bg-white rounded-lg border">
      <div class="px-4 py-3 border-b">
        <h2 class="font-semibold text-gray-900">Work Orders by Status</h2>
      </div>
      <div class="p-4 space-y-3">
        <% WorkOrder.statuses.keys.each do |status| %>
          <% count = @project.work_orders.where(status: status).count %>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-600 capitalize"><%= status.humanize %></span>
            <div class="flex items-center gap-2">
              <div class="w-32 bg-gray-100 rounded-full h-2">
                <% total = @project.work_orders.count %>
                <% pct = total > 0 ? (count.to_f / total * 100).round : 0 %>
                <div class="bg-indigo-500 h-2 rounded-full" style="width: <%= pct %>%"></div>
              </div>
              <span class="text-sm font-medium text-gray-900 w-8 text-right"><%= count %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Documents -->
    <div class="bg-white rounded-lg border">
      <div class="px-4 py-3 border-b flex justify-between items-center">
        <h2 class="font-semibold text-gray-900">Recent Documents</h2>
        <%= link_to "View All", project_documents_path(@project), class: "text-sm text-indigo-600 hover:text-indigo-700" %>
      </div>
      <div class="divide-y">
        <% @project.documents.order(updated_at: :desc).limit(5).each do |doc| %>
          <%= link_to project_document_path(@project, doc), class: "block px-4 py-3 hover:bg-gray-50" do %>
            <p class="text-sm font-medium text-gray-900"><%= doc.title %></p>
            <p class="text-xs text-gray-400 mt-1"><%= doc.document_type.humanize %> &middot; Updated <%= time_ago_in_words(doc.updated_at) %> ago</p>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Recent Feedback -->
    <div class="bg-white rounded-lg border">
      <div class="px-4 py-3 border-b flex justify-between items-center">
        <h2 class="font-semibold text-gray-900">Recent Feedback</h2>
        <%= link_to "View Inbox", project_feedback_items_path(@project), class: "text-sm text-indigo-600 hover:text-indigo-700" %>
      </div>
      <div class="divide-y">
        <% @project.feedback_items.order(created_at: :desc).limit(5).each do |item| %>
          <%= link_to project_feedback_item_path(@project, item), class: "block px-4 py-3 hover:bg-gray-50" do %>
            <div class="flex items-center gap-2">
              <span class="inline-block w-2 h-2 rounded-full <%= item.bug? ? 'bg-red-400' : item.feature_request? ? 'bg-blue-400' : 'bg-gray-400' %>"></span>
              <p class="text-sm font-medium text-gray-900"><%= item.title %></p>
            </div>
            <p class="text-xs text-gray-400 mt-1"><%= item.category.humanize %> &middot; <%= item.status.humanize %> &middot; <%= time_ago_in_words(item.created_at) %> ago</p>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Linked Systems -->
    <div class="bg-white rounded-lg border lg:col-span-2">
      <div class="px-4 py-3 border-b flex justify-between items-center">
        <h2 class="font-semibold text-gray-900">Linked Systems</h2>
        <%= link_to "System Map", systems_path, class: "text-sm text-indigo-600 hover:text-indigo-700" %>
      </div>
      <div class="p-4">
        <% systems = current_user.team.service_systems.limit(10) %>
        <% if systems.any? %>
          <div class="flex flex-wrap gap-2">
            <% systems.each do |sys| %>
              <%= link_to system_path(sys), class: "inline-flex items-center gap-2 px-3 py-1.5 bg-gray-100 hover:bg-gray-200 rounded-lg text-sm" do %>
                <span class="w-2 h-2 rounded-full <%= sys.service? ? 'bg-blue-400' : sys.database? ? 'bg-green-400' : sys.queue? ? 'bg-purple-400' : 'bg-gray-400' %>"></span>
                <%= sys.name %>
                <span class="text-xs text-gray-400"><%= sys.system_type.humanize %></span>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-400">No systems linked yet</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
